# BBS Core v0.1.0 — environment variables
# Copy to `.env` and adjust before running `docker compose up`.
# NEVER commit the real .env file.

# ── Database (MariaDB) ──
DB_HOST=db
DB_PORT=3306
DB_NAME=bbs_core
DB_USER=bbs
DB_PASSWORD=change-me-strong-password

# ── Application ──
APP_SECRET=replace-with-32+char-random-string
PORT=4000
