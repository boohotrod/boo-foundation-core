# BBS Core v0.1.0 — Environment Variables
# ================================================================
# 1. Copy this file to `.env` in the project root:
#    cp .env.example .env
# 2. Edit `.env` and set strong passwords / secrets.
# 3. NEVER commit the real `.env` file to version control.
# ================================================================

# ── Database (MariaDB) ─────────────────────────────────────────
# Hostname inside Docker compose network (use `db`); override with
# `127.0.0.1` for local dev when connecting to an external MariaDB.
DB_HOST=db
DB_PORT=3306
DB_NAME=bbs_core
DB_USER=bbs
# REQUIRED — change to a strong password before first run.
DB_PASSWORD=change-me-strong-password

# ── Application ──────────────────────────────────────────────────
# REQUIRED — 32+ character random string used for signing sessions
# and internal tokens. Generate with:
#   openssl rand -base64 48
APP_SECRET=replace-with-32+char-random-string

# ── First SuperAdmin (v0.2.0 real auth) ───────────────────────
# Used only when the users table is empty during first startup.
# Change SUPERADMIN_PASSWORD immediately after the first successful login.
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=ChangeMe!Admin123

# Express backend port (exposed inside the container network only;
# nginx proxies /api to it automatically).
PORT=4000

# ── Backup (v0.1.2) ─────────────────────────────────────────────
# Scheduled MariaDB dumps stored under BACKUP_PATH (mounted from
# ./backups on the host). Each run produces a timestamped .sql file.
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_PATH=/backups

# ── Optional / Development ───────────────────────────────────────
# Uncomment for local frontend dev talking directly to the backend:
# VITE_API_BASE_URL=http://localhost:4000/api
