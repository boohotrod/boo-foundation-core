# BBS Core v0.2.0 — Environment Variables
# ================================================================
# 1. Copy this file to `.env` in the project root:
#    cp .env.example .env
# 2. Edit `.env` and set strong passwords / secrets.
# 3. NEVER commit the real `.env` file to version control.
# ================================================================

# ── Database (MariaDB) ─────────────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_NAME=bbs_core
DB_USER=bbs
# REQUIRED — change to a strong password before first run.
DB_PASSWORD=change-me-strong-password

# ── Application ──────────────────────────────────────────────────
# REQUIRED in v0.2.0 — 32+ char random string used to sign JWT
# auth tokens. Generate with:
#   openssl rand -base64 48
# Rotating this value invalidates all existing sessions.
APP_SECRET=replace-with-32+char-random-string

# Express backend port (internal Docker network only).
PORT=4000

# ── Auth (v0.2.0) ────────────────────────────────────────────────
# JWT lifetime. Accepts any `vercel/ms` duration: "15m", "1h", "7d".
JWT_EXPIRES_IN=7d
# bcrypt cost factor. 10 is a good production default; raise for
# stronger hashes at the cost of slower logins.
BCRYPT_ROUNDS=10

# SuperAdmin seed — used ONLY on the very first boot when the
# `users` table is empty. Change the password IMMEDIATELY after
# first login (future v0.2.x will expose a UI for this).
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_EMAIL=admin@bbs.local
SUPERADMIN_PASSWORD=ChangeMe!Admin123

# ── Backup (v0.1.2) ─────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_PATH=/backups

# ── Optional / Development ───────────────────────────────────────
# VITE_API_BASE_URL=http://localhost:4000/api
